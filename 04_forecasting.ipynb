   "source": [
    "# Airtel Telecom Analytics — Phase 4: Forecasting & ML Modeling\n",
    "\n",
    "**Tools:** PyCaret (AutoML) · Prophet (Time Series)  \n",
    "**Input:** `airtel_clean_data/*.csv`  \n",
    "**Output:** `airtel_forecast_outputs/` — predictions, model, charts, risk scores\n",
    "\n",
    "---\n",
    "**Steps:**\n",
    "1. Build churn feature table (billing + ticket signals per customer)\n",
    "2. PyCaret AutoML — compare classifiers, select best, predict churn probability\n",
    "3. Prophet — 6-month revenue forecast (fixed: lower changepoint scale for short series)\n",
    "4. Churn risk scoring — segment customers into Low/Medium/High/Critical risk tiers\n",
    "5. Export top 50 at-risk customers for retention intervention\n",
    "\n",
    "**Next:** Export charts + CSVs to Power BI / Looker Studio"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# !pip install pycaret prophet"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from config import *\n",
    "from utils import (log, section, force_numeric, save_fig,\n",
    "                   compute_risk_score, segment_risk, RISK_WEIGHTS,\n",
    "                   reset_log, save_report)\n",
    "\n",
    "section('Phase 4: Forecasting & ML Modeling')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── LOAD & PREP DATA ─────────────────────────────────────────────────────────\n",
    "\n",
    "section('Loading Clean Data')\n",
    "\n",
    "customers = pd.read_csv(f'{CLEAN_DIR}/customers_clean.csv',    parse_dates=['joining_date'])\n",
    "billing   = pd.read_csv(f'{CLEAN_DIR}/billing_clean.csv',      parse_dates=['payment_date','billing_month'])\n",
    "churn     = pd.read_csv(f'{CLEAN_DIR}/churn_events_clean.csv', parse_dates=['churn_date'])\n",
    "tickets   = pd.read_csv(f'{CLEAN_DIR}/support_tickets_clean.csv', parse_dates=['created_date'])\n",
    "\n",
    "# Shared force_numeric from utils — not copy-pasted\n",
    "customers = force_numeric(customers, ['age','tenure_months','plan_price','is_active'])\n",
    "customers['is_active'] = customers['is_active'].fillna(1).astype(int)\n",
    "\n",
    "billing = force_numeric(billing, ['total_amount','arrears','plan_charges','taxes','discount_applied'])\n",
    "tickets = force_numeric(tickets, ['csat_score','handle_time_mins','escalated','first_contact_resolved'])\n",
    "tickets['csat_score']       = tickets['csat_score'].fillna(0)\n",
    "tickets['escalated']        = tickets['escalated'].fillna(0)\n",
    "tickets['handle_time_mins'] = tickets['handle_time_mins'].fillna(tickets['handle_time_mins'].median())\n",
    "churn = force_numeric(churn, ['lifetime_value'])\n",
    "\n",
    "log(f'  customers={len(customers):,} · billing={len(billing):,} · churn={len(churn):,} · tickets={len(tickets):,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── BUILD CHURN FEATURE TABLE ────────────────────────────────────────────────\n",
    "\n",
    "section('Building Churn Feature Table')\n",
    "\n",
    "bill_feat = billing.groupby('customer_id').agg(\n",
    "    total_billed  = ('total_amount', 'sum'),\n",
    "    avg_bill      = ('total_amount', 'mean'),\n",
    "    total_arrears = ('arrears',      'sum'),\n",
    "    unpaid_count  = ('payment_status', lambda x: (x.str.lower() == 'unpaid').sum()),\n",
    "    bill_count    = ('bill_id',      'count')\n",
    ").reset_index()\n",
    "\n",
    "tick_feat = tickets.groupby('customer_id').agg(\n",
    "    ticket_count    = ('ticket_id',        'count'),\n",
    "    avg_csat        = ('csat_score',        'mean'),\n",
    "    escalated_count = ('escalated',         'sum'),\n",
    "    avg_handle_time = ('handle_time_mins',  'mean')\n",
    ").reset_index()\n",
    "tick_feat['avg_csat'] = pd.to_numeric(tick_feat['avg_csat'], errors='coerce').fillna(0)\n",
    "\n",
    "# FIX: keep customer_id throughout — don't drop and re-add by index position\n",
    "churn_feat = customers[[\n",
    "    'customer_id','age','gender','region','plan_type','plan_price',\n",
    "    'tenure_months','contract_type','acquisition_channel','is_active'\n",
    "]].copy()\n",
    "\n",
    "churn_feat = churn_feat.merge(bill_feat, on='customer_id', how='left')\n",
    "churn_feat = churn_feat.merge(tick_feat, on='customer_id', how='left')\n",
    "churn_feat['is_churned'] = churn_feat['customer_id'].isin(churn['customer_id']).astype(int)\n",
    "churn_feat = churn_feat.fillna(0)\n",
    "\n",
    "log(f'  Feature table: {churn_feat.shape[0]:,} rows × {churn_feat.shape[1]} cols')\n",
    "log(f'  Churn rate: {churn_feat[\"is_churned\"].mean()*100:.1f}%')\n",
    "\n",
    "# Save WITH customer_id for downstream risk scoring\n",
    "churn_feat.to_csv(f'{FORECAST_DIR}/churn_feature_table.csv', index=False)\n",
    "log(f'  ✓ Saved → {FORECAST_DIR}/churn_feature_table.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── PYCARET AUTOML ───────────────────────────────────────────────────────────\n",
    "\n",
    "section('PyCaret AutoML — Churn Prediction')\n",
    "\n",
    "# Drop customer_id only for model training (it's not a feature)\n",
    "model_df = churn_feat.drop(columns=['customer_id'])\n",
    "\n",
    "try:\n",
    "    from pycaret.classification import (\n",
    "        setup, compare_models, pull, predict_model, save_model\n",
    "    )\n",
    "\n",
    "    log('  → Setting up PyCaret experiment...')\n",
    "    setup(\n",
    "        data                 = model_df,\n",
    "        target               = 'is_churned',\n",
    "        categorical_features = ['gender','region','plan_type','contract_type','acquisition_channel'],\n",
    "        session_id           = SEED,\n",
    "        verbose              = False,\n",
    "        html                 = False,\n",
    "    )\n",
    "\n",
    "    log('  → Comparing models (AutoML)...')\n",
    "    best_models = compare_models(n_select=3, sort='AUC', verbose=False)\n",
    "    results     = pull()\n",
    "\n",
    "    log('\\n  TOP 3 MODELS BY AUC:')\n",
    "    log(results[['Model','AUC','Accuracy','Recall','Prec.','F1']].head(3).to_string(index=False))\n",
    "\n",
    "    best = best_models[0] if isinstance(best_models, list) else best_models\n",
    "    log(f'\\n  Best model: {type(best).__name__}')\n",
    "\n",
    "    # Predict — on model_df without customer_id\n",
    "    predictions = predict_model(best, data=model_df.drop(columns=['is_churned']))\n",
    "    predictions['customer_id']  = churn_feat['customer_id'].values\n",
    "    predictions['actual_churn'] = model_df['is_churned'].values\n",
    "    predictions.to_csv(f'{FORECAST_DIR}/churn_predictions.csv', index=False)\n",
    "    log(f'  ✓ Predictions saved')\n",
    "\n",
    "    save_model(best, f'{FORECAST_DIR}/airtel_churn_model')\n",
    "    log(f'  ✓ Model saved → airtel_churn_model.pkl')\n",
    "\n",
    "    # Confusion matrix + report\n",
    "    try:\n",
    "        from sklearn.metrics import confusion_matrix, classification_report\n",
    "        import seaborn as sns\n",
    "\n",
    "        y_true = model_df['is_churned'].values\n",
    "        y_pred = predictions['prediction_label'].values\n",
    "        cm     = confusion_matrix(y_true, y_pred)\n",
    "        report = classification_report(y_true, y_pred, output_dict=True)\n",
    "\n",
    "        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "        fig.suptitle('Airtel Churn Model — Performance', fontsize=14, fontweight='bold')\n",
    "\n",
    "        sns.heatmap(cm, annot=True, fmt='d', cmap='RdYlGn',\n",
    "                    xticklabels=['Not Churned','Churned'],\n",
    "                    yticklabels=['Not Churned','Churned'], ax=axes[0])\n",
    "        axes[0].set_title('Confusion Matrix')\n",
    "        axes[0].set_ylabel('Actual')\n",
    "        axes[0].set_xlabel('Predicted')\n",
    "\n",
    "        report_df = pd.DataFrame(report).transpose().round(2)\n",
    "        axes[1].axis('off')\n",
    "        tbl = axes[1].table(cellText=report_df.values, colLabels=report_df.columns,\n",
    "                            rowLabels=report_df.index, loc='center', cellLoc='center')\n",
    "        tbl.auto_set_font_size(False)\n",
    "        tbl.set_fontsize(10)\n",
    "        tbl.scale(1.2, 1.5)\n",
    "        axes[1].set_title('Classification Report', pad=20)\n",
    "\n",
    "        plt.tight_layout()\n",
    "        save_fig(FORECAST_DIR, '07_model_performance')\n",
    "\n",
    "        log(f\"\\n  Churn Recall    : {report['1']['recall']*100:.1f}%\")\n",
    "        log(f\"  Churn Precision : {report['1']['precision']*100:.1f}%\")\n",
    "        log(f\"  Overall Accuracy: {report['accuracy']*100:.1f}%\")\n",
    "    except Exception as e:\n",
    "        log(f'  ⚠ Confusion matrix skipped: {e}')\n",
    "\n",
    "    log('  ✅ PyCaret complete!')\n",
    "\n",
    "except ImportError:\n",
    "    log('  ⚠ PyCaret not installed. Run: pip install pycaret')\n",
    "except Exception as e:\n",
    "    log(f'  ⚠ PyCaret error: {e}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── PROPHET REVENUE FORECASTING ──────────────────────────────────────────────\n",
    "\n",
    "section('Prophet — Revenue Forecasting')\n",
    "\n",
    "try:\n",
    "    from prophet import Prophet\n",
    "\n",
    "    billing['billing_month_dt'] = pd.to_datetime(billing['billing_month'], errors='coerce')\n",
    "    monthly_rev = (\n",
    "        billing[billing['payment_status'].str.lower() == 'paid']\n",
    "        .groupby(billing['billing_month_dt'].dt.to_period('M'))['total_amount']\n",
    "        .sum().reset_index()\n",
    "    )\n",
    "    monthly_rev.columns = ['ds', 'y']\n",
    "    monthly_rev['ds']   = monthly_rev['ds'].dt.to_timestamp()\n",
    "    monthly_rev         = monthly_rev.sort_values('ds').dropna()\n",
    "\n",
    "    log(f'  Training on {len(monthly_rev)} monthly data points')\n",
    "    log(f'  Revenue range: ₹{monthly_rev[\"y\"].min():,.0f} — ₹{monthly_rev[\"y\"].max():,.0f}')\n",
    "\n",
    "    # FIX: changepoint_prior_scale was 0.3 (too flexible for ~12 months).\n",
    "    # PROPHET_CHANGEPOINT_SCALE = 0.05 (set in config.py) gives smoother, less overfit forecasts.\n",
    "    log(f'  changepoint_prior_scale = {PROPHET_CHANGEPOINT_SCALE} (tuned for short series)')\n",
    "\n",
    "    m = Prophet(\n",
    "        yearly_seasonality      = True,\n",
    "        weekly_seasonality      = False,\n",
    "        daily_seasonality       = False,\n",
    "        changepoint_prior_scale = PROPHET_CHANGEPOINT_SCALE,\n",
    "        interval_width          = 0.95,\n",
    "    )\n",
    "    m.fit(monthly_rev)\n",
    "\n",
    "    future   = m.make_future_dataframe(periods=PROPHET_FORECAST_PERIODS, freq='MS')\n",
    "    forecast = m.predict(future)\n",
    "    forecast.to_csv(f'{FORECAST_DIR}/revenue_forecast.csv', index=False)\n",
    "\n",
    "    future_only = forecast[forecast['ds'] > monthly_rev['ds'].max()]\n",
    "\n",
    "    fig, axes = plt.subplots(2, 1, figsize=(14, 10))\n",
    "    fig.suptitle('Airtel — Revenue Forecast (Prophet)', fontsize=15, fontweight='bold')\n",
    "\n",
    "    axes[0].fill_between(forecast['ds'], forecast['yhat_lower'], forecast['yhat_upper'],\n",
    "                         alpha=0.2, color='#3498DB', label='95% CI')\n",
    "    axes[0].plot(forecast['ds'], forecast['yhat'], color='#3498DB', linewidth=2, label='Forecast')\n",
    "    axes[0].scatter(monthly_rev['ds'], monthly_rev['y'], color='#E74C3C', s=50, zorder=5, label='Actual')\n",
    "    axes[0].axvline(monthly_rev['ds'].max(), color='gray', linestyle='--', alpha=0.7, label='Forecast Start')\n",
    "    axes[0].set_title('Monthly Revenue: Actual vs Forecast')\n",
    "    axes[0].set_ylabel('Revenue (₹)')\n",
    "    axes[0].legend()\n",
    "    axes[0].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, p: f'₹{x:,.0f}'))\n",
    "\n",
    "    axes[1].bar(future_only['ds'].dt.strftime('%b %Y'), future_only['yhat'],\n",
    "                color='#2ECC71', alpha=0.8)\n",
    "    axes[1].set_title(f'Next {PROPHET_FORECAST_PERIODS} Months Forecast')\n",
    "    axes[1].set_ylabel('Revenue (₹)')\n",
    "    axes[1].tick_params(axis='x', rotation=30)\n",
    "    axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, p: f'₹{x:,.0f}'))\n",
    "\n",
    "    plt.tight_layout()\n",
    "    save_fig(FORECAST_DIR, '08_revenue_forecast')\n",
    "\n",
    "    log('\\n  6-MONTH FORECAST:')\n",
    "    for _, row in future_only.iterrows():\n",
    "        log(f\"  {row['ds'].strftime('%b %Y')}: ₹{row['yhat']:>10,.0f}  \"\n",
    "            f\"[₹{row['yhat_lower']:,.0f} – ₹{row['yhat_upper']:,.0f}]\")\n",
    "    log(f\"\\n  Total 6-month forecast: ₹{future_only['yhat'].sum():,.0f}\")\n",
    "    log('  ✅ Prophet complete!')\n",
    "\n",
    "except ImportError:\n",
    "    log('  ⚠ Prophet not installed. Run: pip install prophet')\n",
    "except Exception as e:\n",
    "    log(f'  ⚠ Prophet error: {e}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CHURN RISK SCORING ───────────────────────────────────────────────────────\n",
    "\n",
    "section('Churn Risk Scoring')\n",
    "\n",
    "# FIX: risk scoring uses compute_risk_score() from utils.py\n",
    "# Weights are documented in RISK_WEIGHTS dict — not magic numbers in the formula\n",
    "log('  Risk weights (from utils.RISK_WEIGHTS):')\n",
    "for k, v in RISK_WEIGHTS.items():\n",
    "    log(f'    {k:<20}: {v}')\n",
    "\n",
    "risk = churn_feat.copy()\n",
    "risk['churn_risk_score'] = compute_risk_score(risk)\n",
    "risk['risk_segment']     = segment_risk(risk['churn_risk_score'])\n",
    "\n",
    "risk_summary = risk.groupby('risk_segment', observed=True).agg(\n",
    "    customer_count = ('customer_id', 'count'),\n",
    "    avg_risk_score = ('churn_risk_score', 'mean'),\n",
    "    avg_arrears    = ('total_arrears', 'mean'),\n",
    "    avg_tenure     = ('tenure_months', 'mean')\n",
    ").reset_index()\n",
    "\n",
    "log('\\n  RISK SEGMENTATION:')\n",
    "log(risk_summary.to_string(index=False))\n",
    "\n",
    "import seaborn as sns\n",
    "seg_counts = risk['risk_segment'].value_counts()\n",
    "colors_seg = {'Low Risk':'#2ECC71','Medium Risk':'#F39C12','High Risk':'#E67E22','Critical Risk':'#E74C3C'}\n",
    "bar_colors = [colors_seg.get(str(s), '#95A5A6') for s in seg_counts.index]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.suptitle('Airtel — Customer Churn Risk Segmentation', fontsize=14, fontweight='bold')\n",
    "axes[0].bar(seg_counts.index.astype(str), seg_counts.values, color=bar_colors)\n",
    "axes[0].set_title('Customers by Risk Segment')\n",
    "axes[0].set_ylabel('Count')\n",
    "axes[0].tick_params(axis='x', rotation=15)\n",
    "axes[1].pie(seg_counts.values, labels=seg_counts.index.astype(str),\n",
    "            autopct='%1.1f%%', colors=bar_colors, startangle=90)\n",
    "axes[1].set_title('Risk Segment Distribution')\n",
    "plt.tight_layout()\n",
    "save_fig(FORECAST_DIR, '09_churn_risk_segments')\n",
    "\n",
    "top_risk = risk.nlargest(50, 'churn_risk_score')[[\n",
    "    'customer_id','plan_type','tenure_months','total_arrears',\n",
    "    'ticket_count','avg_csat','churn_risk_score','risk_segment'\n",
    "]]\n",
    "top_risk.to_csv(f'{FORECAST_DIR}/top_50_at_risk_customers.csv', index=False)\n",
    "log(f'  ✓ Top 50 at-risk saved → {FORECAST_DIR}/top_50_at_risk_customers.csv')\n",
    "log('  ✅ Risk scoring complete!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "section('Phase 4 Complete')\n",
    "log(f'''\n",
    "  Outputs → {FORECAST_DIR}/\n",
    "    churn_feature_table.csv       (engineered features)\n",
    "    churn_predictions.csv         (model predictions)\n",
    "    airtel_churn_model.pkl        (saved PyCaret model)\n",
    "    revenue_forecast.csv          (Prophet 6-month forecast)\n",
    "    top_50_at_risk_customers.csv  (priority intervention list)\n",
    "\n",
    "    07_model_performance.png\n",
    "    08_revenue_forecast.png\n",
    "    09_churn_risk_segments.png\n",
    "\n",
    "  NEXT → Export to Power BI / Looker Studio\n",
    "''')\n",
    "save_report(f'{FORECAST_DIR}/forecasting_report.txt')"
   ]
  }
