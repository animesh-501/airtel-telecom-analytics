 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Airtel Telecom Analytics — Phase 2: Data Cleaning\n",
    "\n",
    "**Tools:** pandas · SQLite · SQLAlchemy  \n",
    "**Input:** `airtel_raw_data/*.csv`  \n",
    "**Output:** `airtel_clean_data/*.csv` + `airtel_telecom.db` + `cleaning_report.txt`\n",
    "\n",
    "---\n",
    "**Steps per dataset:**\n",
    "1. Remove duplicates\n",
    "2. Standardize string casing\n",
    "3. Strip ` INR` type corruption & coerce numerics\n",
    "4. Impute missing values\n",
    "5. Parse dates\n",
    "6. Validate categorical values against known-good sets\n",
    "7. Remove orphan rows (referential integrity)\n",
    "8. SQL validation via SQLite\n",
    "\n",
    "**Next:** `03_eda.ipynb`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import sqlite3\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from config import *\n",
    "from utils import log, section, snapshot, force_numeric, validate_categorical, reset_log, save_report\n",
    "\n",
    "section('Phase 2: Data Cleaning')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── LOAD RAW DATA ────────────────────────────────────────────────────────────\n",
    "\n",
    "section('Loading Raw Data')\n",
    "\n",
    "customers = pd.read_csv(f'{RAW_DIR}/customers_raw.csv')\n",
    "billing   = pd.read_csv(f'{RAW_DIR}/billing_raw.csv')\n",
    "churn     = pd.read_csv(f'{RAW_DIR}/churn_events_raw.csv')\n",
    "tickets   = pd.read_csv(f'{RAW_DIR}/support_tickets_raw.csv')\n",
    "\n",
    "log('Raw data snapshots (before cleaning):')\n",
    "for name, df in [('customers', customers), ('billing', billing),\n",
    "                 ('churn', churn), ('tickets', tickets)]:\n",
    "    snapshot(df, name)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CLEAN: CUSTOMERS ─────────────────────────────────────────────────────────\n",
    "\n",
    "section('Cleaning: Customers')\n",
    "c = customers.copy()\n",
    "\n",
    "before = len(c)\n",
    "c = c.drop_duplicates(subset=['customer_id'])\n",
    "log(f'  ✓ Duplicates removed: {before - len(c)}')\n",
    "\n",
    "str_cols = ['name','gender','region','state','plan_type','plan_name',\n",
    "            'contract_type','kyc_verified','acquisition_channel','city']\n",
    "for col in str_cols:\n",
    "    if col in c.columns:\n",
    "        c[col] = c[col].astype(str).str.strip().str.title().replace('Nan', np.nan)\n",
    "log('  ✓ Strings standardized (title case)')\n",
    "\n",
    "# FIX: use shared force_numeric from utils — not copy-pasted code\n",
    "c = force_numeric(c, ['age', 'plan_price', 'tenure_months'])\n",
    "log('  ✓ Numerics cleaned')\n",
    "\n",
    "c['gender']              = c['gender'].fillna('Unknown')\n",
    "c['kyc_verified']        = c['kyc_verified'].fillna('No')\n",
    "c['acquisition_channel'] = c['acquisition_channel'].fillna('Unknown')\n",
    "c['email']               = c['email'].fillna('not_provided@unknown.com')\n",
    "c['age']                 = c['age'].fillna(c['age'].median())\n",
    "c['tenure_months']       = c['tenure_months'].fillna(c['tenure_months'].median())\n",
    "c['is_active']           = c['is_active'].fillna(1)\n",
    "log('  ✓ Missing values imputed')\n",
    "\n",
    "c['joining_date'] = pd.to_datetime(c['joining_date'], errors='coerce')\n",
    "log('  ✓ joining_date → datetime')\n",
    "\n",
    "invalid_age = ((c['age'] < 18) | (c['age'] > 80)).sum()\n",
    "c = c[(c['age'] >= 18) & (c['age'] <= 80)]\n",
    "log(f'  ✓ Invalid age rows removed: {invalid_age}')\n",
    "\n",
    "# FIX: schema validation — warn on unexpected categories\n",
    "validate_categorical(c, 'plan_type', VALID_PLAN_TYPES, 'plan_type')\n",
    "c = c[c['plan_type'].isin(VALID_PLAN_TYPES)]\n",
    "\n",
    "snapshot(c, 'customers CLEAN')\n",
    "c.to_csv(f'{CLEAN_DIR}/customers_clean.csv', index=False)\n",
    "log(f'  ✅ Saved → {CLEAN_DIR}/customers_clean.csv')\n",
    "\n",
    "valid_cust_ids = set(c['customer_id'].unique())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CLEAN: BILLING ───────────────────────────────────────────────────────────\n",
    "\n",
    "section('Cleaning: Billing')\n",
    "b = billing.copy()\n",
    "\n",
    "before = len(b)\n",
    "b = b.drop_duplicates(subset=['bill_id'])\n",
    "log(f'  ✓ Duplicates removed: {before - len(b)}')\n",
    "\n",
    "num_cols = ['plan_charges','data_charges','call_charges','sms_charges',\n",
    "            'taxes','discount_applied','total_amount','arrears']\n",
    "b = force_numeric(b, num_cols)\n",
    "log('  ✓ Numerics cleaned')\n",
    "\n",
    "b['data_charges']     = b['data_charges'].fillna(0)\n",
    "b['call_charges']     = b['call_charges'].fillna(0)\n",
    "b['sms_charges']      = b['sms_charges'].fillna(0)\n",
    "b['discount_applied'] = b['discount_applied'].fillna(0)\n",
    "b['arrears']          = b['arrears'].fillna(0)\n",
    "b['payment_method']   = b['payment_method'].fillna('Unknown')\n",
    "b['payment_status']   = b['payment_status'].fillna('Unknown')\n",
    "log('  ✓ Missing values imputed')\n",
    "\n",
    "b['payment_date']  = pd.to_datetime(b['payment_date'],  errors='coerce')\n",
    "b['billing_month'] = pd.to_datetime(b['billing_month'], errors='coerce', format='%Y-%m')\n",
    "b['payment_status'] = b['payment_status'].str.strip().str.title()\n",
    "b['payment_method'] = b['payment_method'].str.strip().str.title()\n",
    "\n",
    "# Recalculate total_amount to catch billing errors\n",
    "b['total_calculated'] = (b['plan_charges'] + b['data_charges'] + b['call_charges']\n",
    "                        + b['sms_charges'] + b['taxes'] - b['discount_applied']).round(2)\n",
    "mismatch = (abs(b['total_amount'] - b['total_calculated']) > 1).sum()\n",
    "log(f'  ✓ Total amount mismatches corrected: {mismatch}')\n",
    "b['total_amount'] = b['total_calculated']\n",
    "b.drop(columns=['total_calculated'], inplace=True)\n",
    "\n",
    "# Validate payment_status\n",
    "validate_categorical(b, 'payment_status', VALID_PAYMENT_STATUS | {'Unknown'}, 'payment_status')\n",
    "\n",
    "before = len(b)\n",
    "b = b[b['customer_id'].isin(valid_cust_ids)]\n",
    "log(f'  ✓ Orphan billing rows removed: {before - len(b)}')\n",
    "\n",
    "snapshot(b, 'billing CLEAN')\n",
    "b.to_csv(f'{CLEAN_DIR}/billing_clean.csv', index=False)\n",
    "log(f'  ✅ Saved → {CLEAN_DIR}/billing_clean.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CLEAN: CHURN ─────────────────────────────────────────────────────────────\n",
    "\n",
    "section('Cleaning: Churn Events')\n",
    "ch = churn.copy()\n",
    "\n",
    "before = len(ch)\n",
    "ch = ch.drop_duplicates(subset=['churn_id'])\n",
    "log(f'  ✓ Duplicates removed: {before - len(ch)}')\n",
    "\n",
    "for col in ['churn_reason','churn_type','was_retained','retention_offer','reactivated','competitor_moved_to']:\n",
    "    if col in ch.columns:\n",
    "        ch[col] = ch[col].astype(str).str.strip().str.title().replace('Nan', np.nan)\n",
    "\n",
    "ch['competitor_moved_to'] = ch['competitor_moved_to'].fillna('Unknown')\n",
    "ch['retention_offer']     = ch['retention_offer'].fillna('None')\n",
    "ch['was_retained']        = ch['was_retained'].fillna('No')\n",
    "ch['reactivated']         = ch['reactivated'].fillna('No')\n",
    "\n",
    "ch = force_numeric(ch, ['lifetime_value'])\n",
    "ch['lifetime_value'] = ch['lifetime_value'].fillna(ch['lifetime_value'].median())\n",
    "\n",
    "ch['churn_date']        = pd.to_datetime(ch['churn_date'],        errors='coerce')\n",
    "ch['reactivation_date'] = pd.to_datetime(ch['reactivation_date'], errors='coerce')\n",
    "\n",
    "validate_categorical(ch, 'churn_type', VALID_CHURN_TYPES, 'churn_type')\n",
    "\n",
    "before = len(ch)\n",
    "ch = ch[ch['customer_id'].isin(valid_cust_ids)]\n",
    "log(f'  ✓ Orphan churn rows removed: {before - len(ch)}')\n",
    "\n",
    "snapshot(ch, 'churn CLEAN')\n",
    "ch.to_csv(f'{CLEAN_DIR}/churn_events_clean.csv', index=False)\n",
    "log(f'  ✅ Saved → {CLEAN_DIR}/churn_events_clean.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CLEAN: SUPPORT TICKETS ───────────────────────────────────────────────────\n",
    "\n",
    "section('Cleaning: Support Tickets')\n",
    "t = tickets.copy()\n",
    "\n",
    "before = len(t)\n",
    "t = t.drop_duplicates(subset=['ticket_id'])\n",
    "log(f'  ✓ Duplicates removed: {before - len(t)}')\n",
    "\n",
    "for col in ['issue_category','priority','channel','resolution_status','assigned_agent']:\n",
    "    if col in t.columns:\n",
    "        t[col] = t[col].astype(str).str.strip().str.title().replace('Nan', np.nan)\n",
    "\n",
    "t['resolution_status'] = t['resolution_status'].fillna('Unresolved')\n",
    "t['issue_category']    = t['issue_category'].fillna('Unknown')\n",
    "t['priority']          = t['priority'].fillna('Medium')\n",
    "t['channel']           = t['channel'].fillna('Unknown')\n",
    "t['csat_score']        = t['csat_score'].fillna(0)\n",
    "t['handle_time_mins']  = t['handle_time_mins'].fillna(t['handle_time_mins'].median())\n",
    "\n",
    "t = force_numeric(t, ['handle_time_mins'])\n",
    "t['created_date']    = pd.to_datetime(t['created_date'],    errors='coerce')\n",
    "t['resolution_date'] = pd.to_datetime(t['resolution_date'], errors='coerce')\n",
    "\n",
    "# Derived: days to resolve\n",
    "t['days_to_resolve'] = (t['resolution_date'] - t['created_date']).dt.days.clip(lower=0)\n",
    "log('  ✓ days_to_resolve derived column added')\n",
    "\n",
    "before = len(t)\n",
    "t = t[t['customer_id'].isin(valid_cust_ids)]\n",
    "log(f'  ✓ Orphan ticket rows removed: {before - len(t)}')\n",
    "\n",
    "snapshot(t, 'tickets CLEAN')\n",
    "t.to_csv(f'{CLEAN_DIR}/support_tickets_clean.csv', index=False)\n",
    "log(f'  ✅ Saved → {CLEAN_DIR}/support_tickets_clean.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── SQL VALIDATION ───────────────────────────────────────────────────────────\n",
    "\n",
    "section('SQL Validation (SQLite)')\n",
    "\n",
    "db_path = f'{CLEAN_DIR}/airtel_telecom.db'\n",
    "conn    = sqlite3.connect(db_path)\n",
    "\n",
    "c.to_sql('customers', conn, if_exists='replace', index=False)\n",
    "b.to_sql('billing',   conn, if_exists='replace', index=False)\n",
    "ch.to_sql('churn',    conn, if_exists='replace', index=False)\n",
    "t.to_sql('tickets',   conn, if_exists='replace', index=False)\n",
    "log(f'  ✓ 4 tables loaded into {db_path}')\n",
    "\n",
    "queries = {\n",
    "    'Customers by Plan Type': '''\n",
    "        SELECT plan_type, COUNT(*) AS total, ROUND(AVG(tenure_months),1) AS avg_tenure\n",
    "        FROM customers GROUP BY plan_type\n",
    "    ''',\n",
    "    'Revenue by Payment Status': '''\n",
    "        SELECT payment_status, COUNT(*) AS bills,\n",
    "               ROUND(SUM(total_amount),0) AS total_revenue\n",
    "        FROM billing GROUP BY payment_status ORDER BY total_revenue DESC\n",
    "    ''',\n",
    "    'Top Churn Reasons': '''\n",
    "        SELECT churn_reason, COUNT(*) AS total,\n",
    "               SUM(CASE WHEN was_retained='Yes' THEN 1 ELSE 0 END) AS retained\n",
    "        FROM churn GROUP BY churn_reason ORDER BY total DESC LIMIT 5\n",
    "    ''',\n",
    "    'Churned Customers with Arrears': '''\n",
    "        SELECT c.customer_id, c.plan_type, ROUND(SUM(b.arrears),0) AS total_arrears,\n",
    "               ch.churn_reason\n",
    "        FROM customers c\n",
    "        JOIN billing b ON c.customer_id = b.customer_id\n",
    "        JOIN churn  ch ON c.customer_id = ch.customer_id\n",
    "        WHERE b.arrears > 0\n",
    "        GROUP BY c.customer_id ORDER BY total_arrears DESC LIMIT 5\n",
    "    ''',\n",
    "}\n",
    "\n",
    "for title, sql in queries.items():\n",
    "    log(f'\\n  SQL: {title}')\n",
    "    result = pd.read_sql(sql, conn)\n",
    "    log(result.to_string(index=False))\n",
    "\n",
    "conn.close()\n",
    "log('  ✅ SQL validation complete!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "section('Phase 2 Complete')\n",
    "log(f'''\n",
    "  Clean CSVs → {CLEAN_DIR}/\n",
    "    customers_clean.csv\n",
    "    billing_clean.csv\n",
    "    churn_events_clean.csv\n",
    "    support_tickets_clean.csv\n",
    "    airtel_telecom.db  (SQLite)\n",
    "\n",
    "  NEXT → Run 03_eda.ipynb\n",
    "''')\n",
    "save_report(f'{CLEAN_DIR}/cleaning_report.txt')"
   ]
  }
